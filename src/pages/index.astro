---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../lib/site";
import { docsNav } from "../lib/navigation";

const docsEntries = await getCollection("docs");

const dateFormatter = new Intl.DateTimeFormat("id-ID", {
  day: "2-digit",
  month: "short",
  year: "numeric"
});

const recentPages = [...docsEntries]
  .filter((entry) => entry.data.updatedAt)
  .map((entry) => ({
    title: entry.data.title,
    href: `/${entry.collection}/${entry.slug}`,
    updatedAt: entry.data.updatedAt as Date,
    description: entry.data.description ?? "Halaman dokumentasi terbaru."
  }))
  .sort((a, b) => b.updatedAt.getTime() - a.updatedAt.getTime())
  .slice(0, 6);

const quickStartSteps = [
  {
    title: "Instalasi",
    description: "Cek requirement sistem dan pasang Bangkah Launcher di proyek Laravel Anda.",
    href: "/docs/installation"
  },
  {
    title: "Quick Start",
    description: "Ikuti langkah setup awal untuk membuat project siap jalan dalam hitungan menit.",
    href: "/docs/quick-start"
  },
  {
    title: "Konfigurasi",
    description: "Atur Docker, database, dan autentikasi sesuai kebutuhan deployment Anda.",
    href: "/docs/docker"
  }
];

const popularLinks = [
  { label: "Persyaratan Sistem", href: "/docs/requirements" },
  { label: "FAQ", href: "/docs/faq" },
  { label: "Troubleshooting", href: "/docs/troubleshooting" },
  { label: "Changelog", href: "/docs/changelog" },
  { label: "GitHub Repository", href: SITE.repo }
];
---

<BaseLayout
  title="Bangkah Launcher Docs | Dokumentasi Resmi"
  description="Dokumentasi resmi Bangkah Launcher untuk instalasi, konfigurasi, penggunaan, dan deployment Laravel project."
  canonicalPath="/"
>
  <main class="home-page">
    <section class="hero">
      <div class="container hero-content">
        <p class="eyebrow">Dokumentasi Resmi</p>
        <h1>Dokumentasi Bangkah Launcher</h1>
        <p>
          Referensi lengkap untuk instalasi, penggunaan, konfigurasi, dan deployment proyek Laravel
          dengan Bangkah Launcher.
        </p>
        <div class="button-row">
          <a class="button primary" href="/docs/quick-start">Mulai Cepat</a>
          <a class="button ghost" href="/docs/about">Lihat Dokumentasi</a>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="container split-layout">
        <article class="panel">
          <h2>Mulai Dalam 3 Langkah</h2>
          <ol class="step-list">
            {quickStartSteps.map((step) => (
              <li>
                <h3><a href={step.href}>{step.title}</a></h3>
                <p>{step.description}</p>
              </li>
            ))}
          </ol>
        </article>

        <article class="panel">
          <h2>Akses Cepat</h2>
          <ul class="quick-links">
            {popularLinks.map((item) => (
              <li>
                <a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="home-section">
      <div class="container">
        <article class="panel searchable-panel">
          <div class="searchable-head">
            <h2>Pencarian Cepat Dokumentasi</h2>
            <p>Cari judul halaman tanpa pindah ke halaman docs.</p>
          </div>

          <label class="search-label" for="docs-search">Cari halaman</label>
          <input id="docs-search" class="search-input" type="search" placeholder="Contoh: installation, docker, troubleshooting" />

          <ul id="docs-search-list" class="search-list" aria-live="polite">
            {docsNav.flatMap((group) =>
              group.items.map((item) => (
                <li data-keywords={`${group.title} ${item.title}`.toLowerCase()}>
                  <a href={`${group.basePath}/${item.slug}`}>{item.title}</a>
                  <span>{group.title}</span>
                </li>
              ))
            )}
          </ul>
        </article>
      </div>
    </section>

    <section class="home-section">
      <div class="container">
        <article class="panel">
          <div class="searchable-head">
            <h2>Halaman Terbaru</h2>
            <p>Diurutkan otomatis berdasarkan field updatedAt di markdown.</p>
          </div>

          {recentPages.length > 0 ? (
            <ul class="recent-list">
              {recentPages.map((page) => (
                <li>
                  <a href={page.href}>{page.title}</a>
                  <p>{page.description}</p>
                  <time datetime={page.updatedAt.toISOString()}>{dateFormatter.format(page.updatedAt)}</time>
                </li>
              ))}
            </ul>
          ) : (
            <p class="muted">Belum ada halaman dengan metadata updatedAt.</p>
          )}
        </article>
      </div>
    </section>

    <section class="home-section">
      <div class="container">
        <h2 class="section-title">Kategori Dokumentasi</h2>
        <p class="section-subtitle">
          Jelajahi dokumentasi berdasarkan topik agar lebih cepat menemukan kebutuhan Anda.
        </p>

        <div class="docs-grid">
          {docsNav.map((group) => (
            <article class="doc-card">
              <h3>{group.title}</h3>
              <ul>
                {group.items.slice(0, 5).map((item) => (
                  <li>
                    <a href={`${group.basePath}/${item.slug}`}>{item.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>

  <style>
    .hero-content {
      text-align: center;
      max-width: 760px;
    }

    .eyebrow {
      display: inline-block;
      background: rgba(0, 71, 255, 0.12);
      color: #003ccf;
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 0;
    }

    .home-section {
      padding: 0.5rem 0 2.8rem;
    }

    .split-layout {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }

    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.2rem;
    }

    .panel h2 {
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 1.15rem;
    }

    .step-list {
      margin: 0;
      padding-left: 1.1rem;
      display: grid;
      gap: 1rem;
    }

    .step-list h3 {
      margin: 0;
      font-size: 1rem;
    }

    .step-list p {
      margin: 0.45rem 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .quick-links {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.55rem;
    }

    .quick-links a {
      display: block;
      text-decoration: none;
      color: #1f2b42;
      background: #f7f9ff;
      border: 1px solid #dce3f6;
      border-radius: 10px;
      padding: 0.62rem 0.72rem;
      font-weight: 600;
    }

    .quick-links a:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .searchable-panel {
      display: grid;
      gap: 0.8rem;
    }

    .searchable-head h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .searchable-head p {
      margin: 0.35rem 0 0;
      color: var(--muted);
    }

    .search-label {
      font-size: 0.88rem;
      font-weight: 600;
      color: #2a344c;
    }

    .search-input {
      border: 1px solid #cfd8ef;
      border-radius: 10px;
      padding: 0.68rem 0.78rem;
      font: inherit;
      width: 100%;
      background: #fbfcff;
    }

    .search-input:focus {
      outline: 2px solid rgba(0, 71, 255, 0.2);
      border-color: var(--accent);
    }

    .search-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.6rem;
    }

    .search-list li {
      border: 1px solid #dae1f4;
      border-radius: 10px;
      padding: 0.62rem 0.7rem;
      background: #f8faff;
      display: grid;
      gap: 0.15rem;
    }

    .search-list a {
      text-decoration: none;
      font-weight: 600;
      color: #20304e;
    }

    .search-list span {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .recent-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.8rem;
    }

    .recent-list li {
      border: 1px solid #d8dce6;
      border-radius: 10px;
      padding: 0.8rem;
      background: #fff;
      display: grid;
      gap: 0.35rem;
    }

    .recent-list a {
      text-decoration: none;
      color: #1d2a46;
      font-weight: 700;
    }

    .recent-list p {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .recent-list time {
      font-size: 0.78rem;
      color: #4e5b77;
    }

    .muted {
      margin: 0;
      color: var(--muted);
    }

    .section-title {
      margin: 0;
      font-size: clamp(1.5rem, 3vw, 2rem);
      text-align: center;
    }

    .section-subtitle {
      margin: 0.6rem auto 1.8rem;
      text-align: center;
      color: var(--muted);
      max-width: 700px;
    }

    .docs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 1rem;
    }

    .doc-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem;
    }

    .doc-card h3 {
      margin: 0 0 0.6rem;
      font-size: 1.02rem;
    }

    .doc-card ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.45rem;
    }

    .doc-card a {
      color: #1f2b42;
      text-decoration: none;
      font-size: 0.94rem;
    }

    .doc-card a:hover {
      color: var(--accent);
    }

    @media (max-width: 768px) {
      .split-layout {
        grid-template-columns: 1fr;
      }

      .button-row {
        flex-direction: column;
        gap: 0.8rem;
      }

      .button {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <script is:inline>
    const input = document.getElementById("docs-search");
    const items = Array.from(document.querySelectorAll("#docs-search-list li"));

    if (input) {
      input.addEventListener("input", (event) => {
        const value = (event.target as HTMLInputElement).value.trim().toLowerCase();

        for (const item of items) {
          const keywords = item.getAttribute("data-keywords") || "";
          item.style.display = keywords.includes(value) ? "grid" : "none";
        }
      });
    }
  </script>
</BaseLayout>
